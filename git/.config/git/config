[user]
    name = Alexandru Gherghescu
    email = gherghescu_alex1@yahoo.ro
    signingKey = gherghescu_alex1@yahoo.ro
[commit]
    gpgsign = true
    template = ~/.config/git/git-commit-template
[core]
    editor = nvim
    pager = "less -+X -R"
    askPass = ksshaskpass
    excludesfile = ~/.config/git/git-ignore
[sendemail]
    smtpserver = smtp.mail.yahoo.com
    smtpuser = gherghescu_alex1@yahoo.ro
    smtpserverport = 587
    smtpencryption = tls
[merge]
	tool = codediff
[mergetool]
	prompt = false
[mergetool "vimdiff"]
    cmd = nvim -d "$LOCAL" "$REMOTE"
[mergetool "codediff"]
	cmd = nvim \"$MERGED\" -c \"CodeDiff merge \\\"$MERGED\\\"\"
[diff]
	tool = codediff
[difftool]
	prompt = false
[difftool "codediff"]
	cmd = nvim \"$LOCAL\" \"$REMOTE\" +\"CodeDiff file $LOCAL $REMOTE\"
[init]
    defaultBranch = main
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
