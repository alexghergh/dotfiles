{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "model": "opus[1m]",
    "effortLevel": "max",
    "permissions": {
        "defaultMode": "default",
        "disableBypassPermissionsMode": "disable",
        "disableAutoMode": "disable",
        "allow": [
            "Bash(git status:*)",
            "Bash(git diff:*)",
            "Bash(git log:*)",
            "Bash(git show:*)",
            "Bash(git fetch:*)",
            "Bash(git remote)",
            "Bash(git remote -v)",
            "Bash(git remote show:*)",
            "Bash(git stash list)",
            "Bash(git stash show:*)",
            "Bash(git blame:*)",
            "Bash(git reflog:*)",
            "Bash(git describe:*)",
            "Bash(git rev-parse:*)",
            "Bash(git ls-files:*)",
            "Bash(git config --get:*)",
            "Bash(git config --list:*)",
            "Bash(git branch)",
            "Bash(git branch -a)",
            "Bash(git branch -v)",
            "Bash(git branch --list:*)",
            "Bash(git worktree list)",
            "Bash(git worktree list:*)",
            "Bash(unzip -l:*)",
            "Bash(* --version)",
            "Bash(* --help)",
            "Bash(* --help *)",
            "WebSearch",
            "WebFetch",
            "Skill",
            "Read(~/.claude/**)",
            "Read(/tmp/claude-*/**)",
            "Write(/tmp/claude-*/**)",
            "Edit(/tmp/claude-*/**)"
        ],
        "ask": [
            "Bash(git add:*)",
            "Bash(git commit:*)",
            "Bash(git reset:*)",
            "Bash(git checkout:*)",
            "Bash(git switch:*)",
            "Bash(git rebase:*)",
            "Bash(git restore:*)",
            "Bash(git clean:*)",
            "Bash(git merge:*)",
            "Bash(git pull:*)",
            "Bash(git rm:*)",
            "Bash(git mv:*)",
            "Bash(git stash)",
            "Bash(git stash pop:*)",
            "Bash(git stash apply:*)",
            "Bash(git stash drop:*)",
            "Bash(git stash clear:*)",
            "Bash(git branch -d:*)",
            "Bash(git branch -D:*)",
            "Bash(rm:*)",
            "Bash(mv:*)",
            "Bash(npm:*)",
            "Bash(pip:*)",
            "Bash(pipx:*)",
            "Bash(uv:*)"
        ],
        "deny": [
            "Bash(rm -rf:*)",
            "Bash(git push:*)",
            "Bash(sudo:*)",
            "Bash(su:*)",
            "Bash(ssh:*)",
            "Bash(dd:*)",
            "Bash(mkfs:*)",
            "Read(**/.env)",
            "Read(**/.env.*)",
            "Read(**/secrets/**)"
        ]
    },
    "sandbox": {
        "enabled": true,
        "failIfUnavailable": true,
        "autoAllowBashIfSandboxed": false,
        "allowUnsandboxedCommands": true,
        "network": {
            "allowedDomains": []
        },
        "filesystem": {
            "allowWrite": [],
            "denyRead": [
                "~/.ssh",
                "~/.gnupg",
                "~/.aws",
                "~/.azure",
                "~/.config/gcloud",
                "~/.kube/config",
                "~/.docker/config.json",
                "~/.netrc",
                "~/.pgpass",
                "~/.npmrc",
                "~/.pypirc",
                "~/.cargo/credentials",
                "~/.password-store",
                "~/.local/share/keyrings",
                "~/.mozilla",
                "~/.config/google-chrome",
                "~/.config/chromium",
                "~/.bash_history",
                "~/.zsh_history",
                "~/.psql_history",
                "~/.mysql_history",
                "/etc/shadow"
            ]
        }
    },
    "hooks": {
        "Notification": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "notify-send 'Claude Code' 'Claude Code needs your attention'"
                    }
                ]
            }
        ]
    },
    "autoUpdatesChannel": "stable",
    "env": {
        "DISABLE_AUTOUPDATER": "1",
        "DISABLE_TELEMETRY": "1",
        "DISABLE_ERROR_REPORTING": "1",
        "DISABLE_FEEDBACK_COMMAND": "1",
        "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
        "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1"
    }
}
